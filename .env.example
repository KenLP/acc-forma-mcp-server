# ============================================================
# acc-forma-mcp-server — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# See docs/AUTH.md for detailed setup instructions.
# NEVER commit .env or *.pem files to version control.

# ----- APS Application Credentials (required) ---------------
APS_CLIENT_ID=your_aps_client_id_here
APS_CLIENT_SECRET=your_aps_client_secret_here

# ----- Authentication Mode ----------------------------------
# ssa (default): Secure Service Account JWT-bearer — recommended
# 2lo:           2-legged client_credentials — limited APIs only
# 3lo:           3-legged PKCE OAuth — Phase 3 (not yet supported)
APS_AUTH_MODE=ssa

# ----- SSA Credentials (required when APS_AUTH_MODE=ssa) ----
# Create an SSA at: https://aps.autodesk.com/en/docs/oauth/v2/tutorials/create-ssa/
SSA_ID=your_service_account_id
SSA_KEY_ID=your_key_id
SSA_KEY_PATH=/path/to/your/private-key.pem

# ----- Region -----------------------------------------------
# US (default) | EMEA | AUS
APS_REGION=US

# ----- Safety: Allow-lists (strongly recommended for production)
# Comma-separated IDs. Use * to allow all (not recommended).
# Hub IDs: get from dm_list_hubs tool.
# Project IDs: get from admin_list_projects or dm_list_projects tool.
FORMA_ALLOWED_HUBS=*
FORMA_ALLOWED_PROJECTS=*

# ----- Safety: Webhook callback hosts ------------------------
# Where webhooks_create may direct Autodesk to POST event data.
# A webhook is ongoing egress: once created, Autodesk keeps sending
# project events to that URL until the hook is deleted.
# Comma-separated hosts; a leading dot (.example.com) matches subdomains.
# * permits any PUBLIC host — loopback/private/link-local are always
# refused (Autodesk cannot reach them; the hook would silently never fire).
FORMA_ALLOWED_CALLBACK_HOSTS=*

# ----- Safety: Mutation mode --------------------------------
# preview_required (default):
#   LLM must call with dry_run=true first, receive approval_token,
#   then re-call with dry_run=false + approval_token to execute.
# client_approval_only:
#   Trust the MCP client's built-in approval UI. Single call executes.
# readonly:
#   Block all mutations. Same as FORMA_READONLY=true.
FORMA_MUTATION_MODE=preview_required

# ----- Safety: Read-only override ---------------------------
# true = immediately block ALL mutation tools regardless of FORMA_MUTATION_MODE
FORMA_READONLY=false

# ----- Audit Log -------------------------------------------
# Directory for daily JSONL audit files (created automatically).
FORMA_AUDIT_DIR=~/.acc-forma-mcp/audit
# none (default) | sqlite (not yet implemented — startup error if set)
FORMA_AUDIT_INDEX=none
# Set false to exclude read tool calls from audit (reduces log size)
FORMA_AUDIT_INCLUDE_READS=true
# Retain audit files for N days. Files older than this are deleted automatically at
# server startup. Must be a positive whole number.
FORMA_AUDIT_RETENTION_DAYS=90
# Fail closed on audit write errors: if true, mutations are aborted when the
# audit log cannot be written (rather than proceeding without an audit record).
# Default: false (fail-open preserves availability but loses tamper evidence).
FORMA_AUDIT_FAIL_CLOSED=false

# ----- Approval Token TTL (seconds) -------------------------
# How long a dry_run=true approval_token stays valid before expiring.
# Must be a positive whole number of seconds — a non-numeric or non-positive value
# fails server startup rather than leaving tokens that never expire.
FORMA_APPROVAL_TOKEN_TTL=300

# ----- Persistence Mode -------------------------------------
# memory (default): approval tokens, rate counters, and idempotency keys are
#   in-memory — lost on restart, not shared across processes.
# sqlite: durable SQLite store — survives restarts, still single-process only.
#   Requires 'better-sqlite3' native module; if 'pnpm install' printed
#   "Ignored build scripts", run 'pnpm approve-builds' first or sqlite mode
#   crashes with "Could not locate bindings".
FORMA_PERSISTENCE_MODE=memory
# Path to the SQLite database file (used only when FORMA_PERSISTENCE_MODE=sqlite).
# FORMA_DB_PATH=~/.acc-forma-mcp/state.db

# ----- Rate Governance --------------------------------------
# Optional: path to JSON config overriding default per-tool hourly rate limits.
# See docs/SAFETY.md for schema.
# FORMA_RATE_CONFIG_PATH=/path/to/rate-config.json

# ----- Logging -----------------------------------------------
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# true = human-readable colored output (dev only; keep false in production)
LOG_PRETTY=false
